# Codex Proxy 环境变量配置
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 代理端口 (默认: 18790)
PORT=18790

# ============================================
# 上游模型 API Key — 按需配置，不用的留空即可
# ============================================

# DeepSeek API Key
# 申请地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Moonshot/Kimi API Key
# 申请地址: https://platform.moonshot.cn
MOONSHOT_API_KEY=

# Agnes AI API Key
# 申请地址: https://agnes-ai.com
AGNES_API_KEY=
