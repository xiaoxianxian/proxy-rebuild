# Multi-Proxy Manager 环境变量配置
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 端口 (默认: 18792)
PORT=18792

# JWT 签名密钥 — 用于签发和验证登录 Token
# 生产环境务必修改默认值，否则 Token 可被伪造
JWT_SECRET=change-me-to-a-random-string

# 管理面板密码 — 可选
# 如果不设置，首次访问会通过 Web UI 引导设置密码
# 如果设置，将直接使用此密码进行登录验证
MANAGER_PASSWORD=

# 测试环境（开发时使用）
# NODE_ENV=test
