# Hermes Multi-Model Proxy Configuration Template
# Copy this file to ~/.hermes/config.yaml and configure your API keys

model:
  base_url: https://apihub.agnes-ai.com/v1
  default: agnes-2.0-flash
  provider: custom

providers:
  deepseek:
    api: https://api.deepseek.com
    name: deepseek
    # api_key: YOUR_DEEPSEEK_API_KEY  # Set via environment variable DEEPSEEK_API_KEY
    models:
      deepseek-v4-flash:
        context_length: 1000000
        name: deepseek-v4-flash
      deepseek-v4-pro:
        context_length: 1000000
        name: deepseek-v4-pro
    default_model: deepseek-v4-flash
    transport: chat_completions
  agnes:
    api: https://apihub.agnes-ai.com/v1
    name: agnes
    # api_key: YOUR_AGNES_API_KEY  # Set via environment variable AGNES_API_KEY
    transport: chat_completions

fallback_providers: []

# Agent settings
agent:
  max_turns: 50
  gateway_timeout: 1800

# Terminal settings
terminal:
  backend: local
  modal_mode: auto
