{
  "name": "cursor-multi-model-proxy",
  "version": "1.0.0",
  "description": "Cursor 多模型代理配置工具 — 让 Cursor 免费版用户可以自由切换多个 AI 模型，支持 OpenAI/Anthropic/Gemini/Ollama 等 Provider",
  "main": "dist/index.js",
  "bin": {
    "cursor-proxy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:proxy": "ts-node src/server/app.ts",
    "dev:web": "cd web && npm run dev",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "db:init": "node scripts/init-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "express": "^4.21.0",
    "helmet": "^8.2.0",
    "openai": "^4.70.0",
    "systeminformation": "^5.23.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "author": "",
  "license": "MIT",
  "keywords": [
    "cursor",
    "proxy",
    "multi-model",
    "openai",
    "anthropic",
    "gemini",
    "ollama"
  ]
}
